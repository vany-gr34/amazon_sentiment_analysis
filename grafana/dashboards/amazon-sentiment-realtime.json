{
  "uid": "sentiment-realtime",
  "title": "Amazon Sentiment Analysis - Real-time Streaming Dashboard",
  "description": "Live sentiment predictions from Amazon reviews streaming pipeline - Focused on Predictions & Metrics",
  "tags": ["real-time", "sentiment-analysis", "amazon", "streaming"],
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
      {
        "id": 1,
        "title": "Total Predictions",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) as total FROM realtime_predictions",
          "editorMode": "code"
        }],
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        },
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 2,
        "title": "Live Rate (5 min)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) as count FROM realtime_predictions WHERE processed_at > NOW() - INTERVAL '5 minutes'",
          "editorMode": "code"
        }],
        "options": {"colorMode": "value", "graphMode": "area"},
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 3,
        "title": "Avg Confidence",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(AVG(confidence), 3) as conf FROM realtime_predictions WHERE confidence IS NOT NULL",
          "editorMode": "code"
        }],
        "options": {"colorMode": "value", "graphMode": "none"},
        "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.6}, {"color": "green", "value": 0.8}]}}}
      },
      {
        "id": 4,
        "title": "Avg Latency (ms)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT ROUND(AVG(api_latency_ms), 2) as latency FROM realtime_predictions WHERE api_latency_ms IS NOT NULL",
          "editorMode": "code"
        }],
        "options": {"colorMode": "value", "graphMode": "none"},
        "fieldConfig": {"defaults": {"unit": "ms", "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}}
      },
      {
        "id": 5,
        "title": "Sentiment Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT prediction as sentiment, COUNT(*) as count FROM realtime_predictions WHERE prediction IS NOT NULL GROUP BY prediction ORDER BY count DESC",
          "editorMode": "code"
        }],
        "options": {"pieType": "pie", "displayLabels": ["name", "percent", "value"], "legend": {"displayMode": "list", "placement": "right"}}
      },
      {
        "id": 6,
        "title": "Predictions Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 4},
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT DATE_TRUNC('minute', processed_at) as time, COUNT(*) as predictions FROM realtime_predictions WHERE processed_at > NOW() - INTERVAL '24 hours' GROUP BY time ORDER BY time",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 7,
        "title": "Confidence Trend",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT DATE_TRUNC('minute', processed_at) as time, AVG(confidence) as avg_confidence FROM realtime_predictions WHERE processed_at > NOW() - INTERVAL '24 hours' AND confidence IS NOT NULL GROUP BY time ORDER BY time",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "hidden"}},
        "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
      },
      {
        "id": 8,
        "title": "Latency Trend",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT DATE_TRUNC('minute', processed_at) as time, AVG(api_latency_ms) as avg_latency FROM realtime_predictions WHERE processed_at > NOW() - INTERVAL '24 hours' AND api_latency_ms IS NOT NULL GROUP BY time ORDER BY time",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "list"}},
        "fieldConfig": {"defaults": {"unit": "ms"}}
      },
      {
        "id": 9,
        "title": "Sentiment Count (24h)",
        "type": "barchart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT prediction, COUNT(*) as count FROM realtime_predictions WHERE processed_at > NOW() - INTERVAL '24 hours' AND prediction IS NOT NULL GROUP BY prediction ORDER BY count DESC",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "list"}, "orientation": "horizontal"},
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 10,
        "title": "Confidence by Sentiment",
        "type": "barchart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT prediction, ROUND(AVG(confidence), 3) as avg_confidence, COUNT(*) as count FROM realtime_predictions WHERE prediction IS NOT NULL AND confidence IS NOT NULL GROUP BY prediction ORDER BY prediction",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "list"}, "orientation": "horizontal"},
        "fieldConfig": {"defaults": {"unit": "percentunit"}}
      },
      {
        "id": 11,
        "title": "Latest Predictions (Last 50)",
        "type": "table",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT id, processed_at, prediction, ROUND(confidence::numeric, 3) as confidence, ROUND(api_latency_ms::numeric, 2) as latency_ms, score FROM realtime_predictions ORDER BY processed_at DESC LIMIT 50",
          "editorMode": "code"
        }],
        "options": {"sortBy": [{"displayName": "processed_at", "desc": true}]}
      },
      {
        "id": 12,
        "title": "Accuracy vs Rating",
        "type": "scatter",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 38},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT score as rating, ROUND(confidence::numeric, 2) as confidence, prediction FROM realtime_predictions WHERE score IS NOT NULL AND confidence IS NOT NULL LIMIT 500",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "list"}}
      },
      {
        "id": 13,
        "title": "Predictions by Hour",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 38},
        "targets": [{
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT DATE_TRUNC('hour', processed_at) as time, COUNT(*) as predictions FROM realtime_predictions GROUP BY DATE_TRUNC('hour', processed_at) ORDER BY time DESC LIMIT 72",
          "editorMode": "code"
        }],
        "options": {"legend": {"displayMode": "list"}},
        "fieldConfig": {"defaults": {"unit": "short"}}
      },
      {
        "id": 14,
        "title": "Streaming Metrics Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 46},
        "targets": [{
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT batch_id) as batches, COUNT(*) as metrics FROM streaming_metrics",
          "editorMode": "code"
        }],
        "options": {"colorMode": "value", "graphMode": "none"},
        "fieldConfig": {"defaults": {"unit": "short"}}
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
      "time_options": ["1h", "6h", "12h", "24h", "7d"]
    },
    "schemaVersion": 36,
    "version": 2,
    "autoRefresh": "10s"
}
