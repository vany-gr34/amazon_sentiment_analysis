# Exclude development artifacts, caches, temporary files, and IDE metadata.
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.log
*.tmp
*.bak
*.swp
*~
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
env/
venv/
.venv/
ENV/
env.bak/

# Exclude local model caches and large files that should not be baked into the image.
*.ckpt
*.pt
*.pth
*.bin
*.h5
*.parquet
*.pickle
*.pkl
*.joblib
*.cache/
*.ipynb

# Keep only source code and requirements needed for the service.
